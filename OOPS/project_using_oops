from abc import ABC, abstractmethod

class Transfer(ABC):
    def __init__(self, account_no, balance):
        self.__account_no = account_no
        self.__balance = balance

    @property
    def balance(self):
        return self.__balance

    @balance.setter
    def balance(self, amount):
        if amount >= 0:
            self.__balance = amount
        else:
            print("Invalid amount")
    
    @property
    def account_no(self):
        return self.__account_no

    @abstractmethod
    def transfer_amount(self, amount):
        pass

    # This is the display method you need
    def display(self):
        print("\n" + "*"*25)
        print(f"Final Balance: ₹{self.balance}")
        print("*"*25)

class NEFT(Transfer):
    def transfer_amount(self, amount):
        if amount <= self.balance:
            self.balance -= amount
            print("Amount transferred successfully via NEFT")
            return True # Important for the 'if' in main
        else:
            print("Insufficient funds")
            return False

class RTGS(Transfer):
    def transfer_amount(self, amount):
        total = amount + (amount * 0.02)
        if total <= self.balance:
            self.balance -= total 
            print("Amount transferred successfully via RTGS")
            return True
        else:
            print("Insufficient funds")
            return False

class IMPS(Transfer):
    def transfer_amount(self, amount):
        total = amount + (amount * 0.05)
        if total <= self.balance:
            self.balance -= total 
            print("Amount transferred successfully via IMPS")
            return True
        else:
            print("Insufficient funds")
            return False

def main():
    acc = int(input("Enter account no: "))
    bal = float(input("Enter balance: "))
    print("1.NEFT\n2.IMPS\n3.RTGS")
    ch = int(input("Enter your choice: "))
    
    # We create a reference variable 'obj'
    obj = None

    if ch == 1:
        obj = NEFT(acc, bal)
    elif ch == 2:
        obj = IMPS(acc, bal)
    elif ch == 3:
        obj = RTGS(acc, bal)
    else:
        print("Invalid choice")
        return

    amt = float(input("Enter amount to transfer: "))
    
    # This checks the 'return True' from the methods
    if obj.transfer_amount(amt):
        obj.display() # This shows the balance!

if __name__ == "__main__":
    main()